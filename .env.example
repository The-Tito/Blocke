# ─────────────────────────────────────────────────────────────
# Bloque — variables de entorno del cliente (Vite)
# Copia este archivo a `.env` y rellena los valores.
# Solo se incluyen valores PÚBLICOS: la anon key es segura de
# exponer PORQUE todas las tablas tienen RLS habilitado.
# ─────────────────────────────────────────────────────────────

# URL del proyecto Supabase "Organizador"
VITE_SUPABASE_URL=https://sehvjozffzbqeyaatwqn.supabase.co

# Clave anónima (publishable) del proyecto Supabase
VITE_SUPABASE_ANON_KEY=PEGA_AQUI_TU_ANON_KEY

# ─────────────────────────────────────────────────────────────
# NOTA: La GROQ_API_KEY NO va aquí. Vive como secret del proyecto
# Supabase (Edge Functions) y nunca llega al navegador.
# Configúrala en: Supabase Dashboard → Edge Functions → Secrets
#   GROQ_API_KEY=...
# ─────────────────────────────────────────────────────────────
